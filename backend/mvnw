# ----------------------------------------------------------------------------
# Maven Wrapper Unix 启动脚本 (mvnw)
# 作用：同 mvnw.cmd，用于 Linux/macOS 系统。
# 自动下载并使用指定版本的 Maven，无需全局安装。
# ----------------------------------------------------------------------------

# 查找 Java 可执行文件
# 注意：JAVA_HOME 可能指向不存在的路径（如 Windows 的 %JDK-21），需要验证
if [ -n "$JAVA_HOME" ] && [ -x "$JAVA_HOME/bin/java" ] ; then
    JAVA_EXEC="$JAVA_HOME/bin/java"
else
    JAVA_EXEC="java"
fi

# Maven Wrapper JAR 的位置
MAVEN_HOME=$(cd "$(dirname "$0")" && pwd)
WRAPPER_JAR="$MAVEN_HOME/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$MAVEN_HOME/.mvn/wrapper/maven-wrapper.properties"

# JVM 参数
MAVEN_OPTS="${MAVEN_OPTS:--Xmx1024m -XX:MaxMetaspaceSize=256m}"

# 执行
exec "$JAVA_EXEC" \
  $MAVEN_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_HOME" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
