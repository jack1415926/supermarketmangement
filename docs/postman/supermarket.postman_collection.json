{
  "info": {
    "name": "超市管理系统 API",
    "description": "小型超市管理系统后端 API 测试集合\n\n作者：C 角（数据库 + 测试 + 文档）\n\n使用方法：\n1. 启动后端项目（mvn spring-boot:run）\n2. 导入此 collection 到 Postman\n3. 先跑 'Auth → Login' 拿 token（自动保存到变量）\n4. 其他接口自动用 Bearer Token 调\n5. base_url 默认 http://localhost:8080，可在变量中改",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "newCategoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "newProductId",
      "value": "",
      "type": "string"
    },
    {
      "key": "newMemberId",
      "value": "",
      "type": "string"
    },
    {
      "key": "activeShiftId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. 认证 Auth",
      "item": [
        {
          "name": "Login (公开)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('登录成功', () => pm.expect(json.code).to.eql(200));",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('✓ Token 已保存到变量');",
                  "} else {",
                  "    console.log('✗ 未拿到 token，检查用户名密码');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - 错误密码 (公开)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrong_password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "pm.test('有 username', () => pm.expect(pm.response.json().data).to.have.property('username'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
