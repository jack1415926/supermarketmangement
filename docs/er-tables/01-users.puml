@startuml
title users（系统用户）

entity "users（系统用户）" as users {
  id : BIGINT <<PK>>  // PK auto
  username : VARCHAR(50) <<unique>>  // unique
  password : VARCHAR(100)  // BCrypt 加密
  display_name : VARCHAR(50)
  role : VARCHAR(20)  // CASHIER/MANAGER/ADMIN
  status : INT  // 1启用 0禁用
  created_at : DATETIME
  updated_at : DATETIME
}
@enduml