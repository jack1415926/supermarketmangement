@startuml
title sale_items（销售明细）

entity "sale_items（销售明细）" as sale_items {
  id : BIGINT <<PK>>  // PK auto
  sale_id : BIGINT <<FK>>  // FK -> sales.id
  product_id : BIGINT <<FK>>  // FK -> products.id
  quantity : INT  // 销售数量
  sale_price : DECIMAL(10,2)  // 销售单价
  subtotal : DECIMAL(12,2)  // quantity × price
}
@enduml